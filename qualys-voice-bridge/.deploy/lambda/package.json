{
  "name": "qualys-voice-bridge",
  "version": "0.1.0",
  "private": true,
  "description": "Production-ready TypeScript scaffold for an AWS Lambda voice adapter POC.",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rimraf coverage dist",
    "format": "prettier . --check",
    "format:write": "prettier . --write",
    "generate:contracts": "node scripts/generate-suva-types.mjs",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "vitest run --coverage",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.test.json",
    "verify": "npm run lint && npm run format && npm run typecheck && npm run test && npm run build"
  },
  "dependencies": {
    "ajv": "^8.17.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.22.0",
    "@types/aws-lambda": "^8.10.147",
    "@types/node": "^22.13.14",
    "@vitest/coverage-v8": "^3.0.8",
    "eslint": "^9.22.0",
    "eslint-config-prettier": "^10.1.1",
    "globals": "^16.0.0",
    "json-schema-to-typescript": "^15.0.4",
    "prettier": "^3.5.3",
    "rimraf": "^6.0.1",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.26.0",
    "vitest": "^3.0.8"
  }
}
