{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://qualys.example/contracts/suva-request.schema.json",
  "title": "SuvaRequest",
  "description": "SUVA request payload forwarded by the Lambda adapter.",
  "type": "object",
  "additionalProperties": false,
  "required": ["sessionId", "callerId", "language", "utterance", "metadata"],
  "properties": {
    "sessionId": {
      "type": "string"
    },
    "callerId": {
      "type": "string"
    },
    "language": {
      "type": "string"
    },
    "utterance": {
      "type": "string"
    },
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": ["awsContactId", "source"],
      "properties": {
        "awsContactId": {
          "type": "string",
          "minLength": 1
        },
        "source": {
          "type": "string"
        }
      }
    }
  }
}
