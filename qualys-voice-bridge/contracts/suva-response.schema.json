{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://qualys.example/contracts/suva-response.schema.json",
  "title": "SuvaResponse",
  "description": "SUVA response payload returned to the Lambda adapter.",
  "type": "object",
  "additionalProperties": false,
  "required": ["status", "replyText", "voiceText", "confidence", "handoff"],
  "properties": {
    "status": {
      "type": "string",
      "enum": ["ANSWER", "ESCALATE", "RETRY"]
    },
    "replyText": {
      "type": "string"
    },
    "voiceText": {
      "type": "string"
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "handoff": {
      "type": "boolean"
    },
    "caseId": {
      "type": "string"
    },
    "reason": {
      "type": "string"
    }
  }
}
